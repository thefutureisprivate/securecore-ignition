  "systemd": {
    "units": [
      {
        "contents": "[Unit]\nDescription=Rebase system to securecore\n# We run after `systemd-machine-id-commit.service` to ensure that\n# `ConditionFirstBoot=true` services won't rerun on the next boot.\nAfter=systemd-machine-id-commit.service\nAfter=network-online.target\nBefore=zincati.service\nConditionPathExists=!/var/lib/%N.stamp\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/bin/systemctl disable --now zincati.service\nExecStart=/usr/bin/systemctl stop rpm-ostreed-automatic.timer rpm-ostreed-automatic.service\nExecStart=/usr/bin/rpm-ostree rebase ostree-image-signed:docker://ghcr.io/secureblue/securecore-main-hardened:latest\nExecStart=/usr/bin/cp /usr/etc/containers/policy.json /etc/containers/policy.json\nExecStart=/usr/bin/rm /etc/pki/containers/secureblue-2025.pub\nExecStart=/usr/bin/systemctl start gvisor-auto-update.service\nExecStart=/usr/bin/touch /var/lib/%N.stamp\nExecStart=/usr/bin/systemctl --no-block reboot\n[Install]\nWantedBy=multi-user.target",
        "enabled": true,
        "name": "rebase.service"
      },
      {
        "contents": "[Unit]\nConditionPathExists=/var/lib/rebase.stamp\n[Service]\nType=oneshot\nRemainAfterExit=yes\nExecStart=/usr/bin/systemctl mask --now zincati.service\nExecStart=/usr/bin/bash -c \"/usr/bin/printf 'n\\ny\\ny\\n' | /usr/bin/ujust set-kargs-hardening\"\nExecStart=/usr/bin/bash -c \"/usr/bin/printf 'secureblue\\nsecureblue\\n' | /usr/bin/mokutil --import /usr/share/pki/akmods/certs/akmods-secureblue.der\"\nExecStart=/usr/bin/ujust dns-selector resolver unbound\nExecStart=/usr/bin/ujust dns-selector dnssec on\nExecStart=/usr/bin/install -d -o thefutureisprivate -g thefutureisprivate -m 700 /var/home/thefutureisprivate/.config\nExecStart=/usr/bin/install -o thefutureisprivate -g thefutureisprivate -m 600 /dev/null /var/home/thefutureisprivate/.config/no-show-user-motd\nExecStart=/usr/bin/ujust toggle-bash-environment-lockdown true true\nExecStart=/usr/bin/ujust set-container-userns on\nExecStart=/usr/bin/rpm-ostree install qemu-guest-agent\nExecStart=/usr/bin/systemctl disable rebase\nExecStart=/usr/bin/rm /etc/systemd/system/rebase.service\nExecStart=/usr/bin/rm /var/lib/rebase.stamp\nExecStart=/usr/bin/systemctl disable postrebase\nExecStart=/usr/bin/rm /etc/systemd/system/postrebase.service\nExecStart=/usr/bin/systemctl --no-block reboot\n[Install]\nWantedBy=multi-user.target",
        "enabled": true,
        "name": "postrebase.service"
      },
      {
        "enabled": true,
        "name": "podman-auto-update.timer"
      }
    ]
  }
}
